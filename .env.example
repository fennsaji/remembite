# ──────────────────────────────────────────────────────────────────────────────
# Remembite Backend — Environment Variables
#
# Copy this file to .env.api and fill in any missing values.
# Never commit .env.api to version control.
#
# ✅ = value already configured in .env.api
# ⚠️  = needs a different value in production
# ❌ = not yet configured — must be set before deploying
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# ⚠️  Dev uses the local docker-compose postgres. Production uses Neon.
#
# How to get (production):
#   1. neon.tech → your project → Dashboard
#   2. "Connection Details" → "Connection string" → copy the postgres:// URL
#
DATABASE_URL=postgres://example:example@localhost:5433/example

# ── JWT ───────────────────────────────────────────────────────────────────────
# ✅ JWT_SECRET already generated.
#
# To regenerate: openssl rand -hex 64
#
JWT_SECRET=

# Access token lifetime in HOURS (default: 24). Config key is JWT_ACCESS_EXPIRY_HOURS.
# Note: NOT _SECS. The unit is hours.
JWT_ACCESS_EXPIRY_HOURS=24

# Refresh token lifetime in DAYS (default: 30). Config key is JWT_REFRESH_EXPIRY_DAYS.
# Note: NOT _SECS. The unit is days.
JWT_REFRESH_EXPIRY_DAYS=30

# ── Google OAuth ───────────────────────────────────────────────────────────────
# ✅ GOOGLE_CLIENT_ID already configured.
#
# How to get:
#   1. console.cloud.google.com → APIs & Services → Credentials
#   2. Find the "Web client" OAuth 2.0 Client ID → copy the Client ID
#   (This is the Web client, not the Android client used by the Flutter app)
#
GOOGLE_CLIENT_ID=

# ── LLM / Gemini ──────────────────────────────────────────────────────────────
# ✅ GEMINI_API_KEY already configured.
#
# How to get:
#   1. aistudio.google.com → Get API Key → Create API key
#
LLM_PROVIDER=gemini
GEMINI_API_KEY=

# ── Google Play Billing ────────────────────────────────────────────────────────
# ✅ GOOGLE_PLAY_SERVICE_ACCOUNT_JSON already configured.
# ✅ GOOGLE_PUBSUB_WEBHOOK_TOKEN already configured.
#
# How to get GOOGLE_PLAY_SERVICE_ACCOUNT_JSON:
#   1. Google Play Console → Setup → API access
#   2. Link to a Google Cloud project if not already linked
#   3. Create a service account → Grant "Financial data" + "Orders" permissions
#   4. Google Cloud Console → IAM → Service Accounts → your account → Keys → Add Key → JSON
#   5. Open the downloaded .json file, paste the entire contents as a single line
#      (remove all real newlines — keep \n as literal text inside the JSON string)
#
# How to get GOOGLE_PUBSUB_WEBHOOK_TOKEN:
#   Any random string used to verify Google Pub/Sub webhook calls.
#   Generate: openssl rand -base64 32
#
GOOGLE_PLAY_PACKAGE_NAME=com.fennsaji.remembite
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PUBSUB_WEBHOOK_TOKEN=

# ── Storage / Cloudflare R2 ────────────────────────────────────────────────────
# ✅ All R2 values already configured.
#
# How to get:
#   1. dash.cloudflare.com → R2 Object Storage → Overview
#   2. R2_ACCOUNT_ID: top-right of the R2 overview page ("Account ID")
#   3. R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY: "Manage R2 API Tokens" → Create API Token
#      (set permission: "Object Read & Write" for your bucket)
#   4. R2_BUCKET: the bucket name you created (remembite-images)
#   5. R2_PUBLIC_URL: your bucket's public URL
#      - If using r2.dev: Settings → Public access → r2.dev subdomain
#      - If using custom domain (recommended): Settings → Custom Domains → your domain
#
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=remembite-images
R2_PUBLIC_URL=

# ── Firebase / FCM ─────────────────────────────────────────────────────────────
# ✅ FCM_SERVICE_ACCOUNT_JSON already configured.
# ✅ FCM_PROJECT_ID already configured (remembite-7df00).
#
# How to get FCM_SERVICE_ACCOUNT_JSON:
#   1. console.firebase.google.com → Remembite project → Project Settings → Service Accounts
#   2. "Generate new private key" → download JSON
#   3. Paste the entire JSON as a single line (keep \n as literal text, remove real newlines)
#
# How to get FCM_PROJECT_ID:
#   Firebase Console → Project Settings → General → "Project ID"
#
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=remembite-7df00

# ── Server ─────────────────────────────────────────────────────────────────────
# ⚠️  Change APP_ENV to "production" and RUST_LOG to info-level in production.
#
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
APP_ENV=development       # production: set to "production"
RUST_LOG=remembite=debug,tower_http=info   # production: remembite=info,tower_http=warn
