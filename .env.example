# ──────────────────────────────────────────────
# Remembite Backend — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ──────────────────────────────────────────────

# ── Database ──────────────────────────────────
# Local dev: uses the docker-compose postgres service
DATABASE_URL=postgres://remembite:remembite@localhost:5432/remembite

# ── JWT ───────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_use_openssl_rand_hex_64
# Access token lifetime in seconds (default: 900 = 15 min)
JWT_ACCESS_EXPIRY_SECS=900
# Refresh token lifetime in seconds (default: 2592000 = 30 days)
JWT_REFRESH_EXPIRY_SECS=2592000

# ── Google OAuth ──────────────────────────────
# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── LLM / Gemini ──────────────────────────────
# Provider name: "gemini" (only supported option for now)
LLM_PROVIDER=gemini
# From Google AI Studio (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# ── Google Play Billing ───────────────────────
# Service account JSON key for server-side purchase verification
# Generate from Google Play Console → Setup → API access
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=/path/to/service_account.json
# Your Android app package name
GOOGLE_PLAY_PACKAGE_NAME=com.fennsaji.remembite

# ── Storage / Cloudflare R2 ───────────────────
# From Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=remembite-images
# Public URL prefix for served images (from R2 custom domain or r2.dev)
R2_PUBLIC_URL=https://images.remembite.com

# ── Firebase / FCM ───────────────────────────
# Required for push notifications after dish classification completes.
# 1. Go to Firebase Console → Project Settings → Service Accounts
# 2. Click "Generate new private key" → download the JSON file
# 3. Paste the entire JSON content as a single-line string below
FCM_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# Your Firebase project ID (found in Firebase Console → Project Settings → General)
FCM_PROJECT_ID=your-firebase-project-id

# ── Server ────────────────────────────────────
# Address and port the Axum server binds to
BIND_ADDR=0.0.0.0:8080
# App environment: "development" | "production"
APP_ENV=development
# Rust log filter (tracing)
RUST_LOG=remembite=debug,tower_http=info
